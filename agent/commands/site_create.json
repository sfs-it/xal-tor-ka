{
  "description": "Provision a site: OS user in docker-hosting + rendered compose (not started)",
  "timeout_seconds": 60,
  "params": {
    "name":        { "required": true,  "pattern": "[a-z][a-z0-9-]{1,30}" },
    "domain":      { "required": false, "pattern": "[a-z0-9]([a-z0-9.-]*[a-z0-9])?" },
    "template":    { "required": false, "enum": ["php-fpm", "static", "custom"] },
    "php_version": { "required": false, "enum": ["8.3", "8.2", "8.1", "7.4"] }
  }
}
