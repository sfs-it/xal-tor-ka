# Copia in .env e adatta. docker-compose legge automaticamente .env.
# Porta HTTP pubblica esposta da NGINX.
HTTP_PORT=80
# URL pubblico del gateway (usato per i cookie Secure e i redirect).
GATE_URL=http://localhost
# Modalità TLS: external (TLS terminato a monte) | selfsigned | acme.
TLS_MODE=external
# IP/CIDR autorizzato all'area admin (il TUO IP pubblico/VPN in produzione).
ADMIN_CIDR=127.0.0.1/32
# Rete da cui accettare gli header X-Forwarded-* (la subnet docker o il proxy a monte).
EDGE_CIDR=172.16.0.0/12
# UID/GID dell'utente host proprietario dei file di config (per i bind mount).
PUID=1000
PGID=1000

# --- Deployment knobs (portabilità oltre Docker) ---------------------------
# Profilo di deploy: docker (default) | host.
#   docker → reload NGINX a carico del container nginx (polling); localhost upstream → host.docker.internal
#   host   → reload via "nginx -s reload"; localhost upstream → 127.0.0.1
# Le due variabili sotto sovrascrivono i default del profilo se valorizzate.
DEPLOY_MODE=docker
# Comando per ricaricare NGINX dopo la rigenerazione dei vhost (solo deploy non-Docker).
# Es.: "nginx -s reload" oppure "systemctl reload nginx". Vuoto = nessun reload (Docker).
NGINX_RELOAD_CMD=
# Host a cui tradurre gli upstream "localhost"/"127.0.0.1" inseriti da admin.
# Docker: host.docker.internal · host/LXD: 127.0.0.1 · vuoto = nessuna traduzione.
UPSTREAM_LOCALHOST=host.docker.internal
